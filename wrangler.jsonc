{
  // Cloudflare Workers(静的アセット配信)でピタフレをホスティングする設定。
  // ビルド(npm run build)で dist/ を生成し、それを静的サイトとして配信する。
  // Worker スクリプト(main)は無し = 純粋な静的ホスティング。
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "pita-friends",
  "compatibility_date": "2025-07-01",
  "assets": {
    "directory": "./dist",
    // 未知のパスは index.html を返す(SPAフォールバック)
    "not_found_handling": "single-page-application"
  }
}
